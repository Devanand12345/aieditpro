# File Conversion (CloudConvert API)
# Get free API key at https://cloudconvert.com (25 conversions/day free)
# CLOUDCONVERT_API_KEY=cloudconvert_your_api_key_here

# Email Configuration
# Choose: gmail, SendGrid, Outlook, or custom SMTP

# Gmail Setup:
# 1. Enable 2-Step Verification on Gmail account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate App Password for "Mail" on "Windows Computer"
# 4. Copy the 16-character password below

EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
RECIPIENT_EMAIL=support@aieditpro.net

# Alternative: SendGrid
# EMAIL_SERVICE=SendGrid
# EMAIL_USER=apikey
# EMAIL_PASSWORD=SG.your-sendgrid-api-key

# Alternative: Outlook/Microsoft 365
# EMAIL_SERVICE=outlook
# EMAIL_USER=your-email@outlook.com
# EMAIL_PASSWORD=your-password
